APP_NAME="Minority Report"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=zh_TW
APP_FALLBACK_LOCALE=zh_TW
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# 本機單獨用 Herd / artisan serve、不需 worker：sync（POST 會阻塞至跑完，需 CONSENSUS_REQUEST_TIMEOUT_SECONDS）
# 非同步 + Show 頁三欄漸進顯示：database + queue:listen（見 README）
QUEUE_CONNECTION=database

# Consensus / LLM 逾時（秒）
CONSENSUS_REQUEST_TIMEOUT_SECONDS=300
CONSENSUS_JOB_TIMEOUT_SECONDS=330
CONSENSUS_PROVIDER_TIMEOUT_SECONDS=90
CONSENSUS_EXTRACTOR_TIMEOUT_SECONDS=30

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel AI SDK（已安裝 laravel/ai；設定見 config/ai.php）
# 雲端 key（擇一或搭配 LOCAL_AI_API_URL 用於本機 proxy）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# 本機 LLM proxy（OpenAI-compatible；覆寫 OpenAI provider 的 api url）
# 設定後 openai consensus provider 視為 enabled（即使無雲端 key）
LOCAL_AI_API_URL=
# 範例（本機 llama.cpp / OpenAI-compatible）：
# LOCAL_AI_API_URL=http://127.0.0.1:8080/v1
# OPENAI_API_KEY=local
# OPENAI_MODEL=gemma-4-E2B_q4_0-it.gguf

# Consensus 逾時（秒；本機慢模型建議保留預設）
# CONSENSUS_REQUEST_TIMEOUT_SECONDS=300
# CONSENSUS_JOB_TIMEOUT_SECONDS=330
# CONSENSUS_PROVIDER_TIMEOUT_SECONDS=90

# M8-B Grounding（Admin UI 為主；以下為 seeder / 開發預設參考）
# GROUNDING_SEARCH_API_KEY=          # Tavily / Serper 等（production search_api mode）
# M8_B_LIVE_GROUNDING=0              # opt-in live grounding integration test

# M8-A Email verification（本機開發可設 true 自動通過驗證；測試覆寫見 .env.testing）
AUTH_AUTO_VERIFY_EMAIL=true

# M8-C Semantic alignment（opt-in live integration test）
# M8_C_LIVE_SEMANTIC=0

# 初始 admin（php artisan db:seed → AdminUserSeeder）
ADMIN_EMAIL=
ADMIN_PASSWORD=
