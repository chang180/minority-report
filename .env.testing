# PHPUnit / php artisan test 專用（可提交至版控）
# Laravel 在 APP_ENV=testing 時會載入本檔，覆寫 .env 的對應值。
# 不含真實 API key 或資料庫帳密；整合測試請在本機以環境變數 opt-in。

APP_NAME="Minority Report"
APP_ENV=testing
# APP_KEY：由 tests/bootstrap.php 於執行時注入（勿提交至版控）
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
BROADCAST_CONNECTION=null

BCRYPT_ROUNDS=4

# 測試必須能驗證「未驗證 email 會被 redirect」；不可沿用 .env.example 的 true
AUTH_AUTO_VERIFY_EMAIL=false

CONSENSUS_PARALLEL_ENABLED=false

# 雲端 / 本機 LLM（測試預設留空；fake provider 為主）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LOCAL_AI_API_URL=

# Opt-in live integration tests（預設關閉）
M3_B_LIVE_OPENAI=0
M8_B_LIVE_GROUNDING=0
M8_C_LIVE_SEMANTIC=0

# Seeder 用占位（非 production 憑證）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password
